datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(uuid())
  phoneNumber     String         @unique
  stellarWallet   String?        @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  groups          GroupMember[]
  contributions   Contribution[]
}

model SavingsGroup {
  id                   String         @id @default(uuid())
  name                 String
  contributionAmount   Float
  contributionFrequency String        // e.g., "WEEKLY", "MONTHLY"
  stellarContractId    String?        // Soroban contract ID once deployed
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  members              GroupMember[]
}

model GroupMember {
  id             String        @id @default(uuid())
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  group          SavingsGroup  @relation(fields: [groupId], references: [id])
  groupId        String
  role           String        @default("MEMBER") // e.g., "CREATOR", "MEMBER"
  joinedAt       DateTime      @default(now())

  @@unique([userId, groupId])
}

model Contribution {
  id             String        @id @default(uuid())
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  groupId        String
  amount         Float
  transactionHash String?
  status         String        @default("PENDING") // PENDING, COMPLETED, FAILED
  createdAt      DateTime      @default(now())
}
